---
import BaseHead from '../components/BaseHead.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const SITE_TITLE = 'Dream Journal — Map Your Inner World | CC3PO Stories';
const SITE_DESCRIPTION = 'Tell us your dream when you wake up. We draw the scene, compose music that matches the feeling, and map your inner world over time. Starting at $9/mo.';
const canonicalURL = new URL(Astro.url.pathname, 'https://stories.cc3po.com');
const ogImage = 'https://cc3po.com/wp-content/uploads/2026/04/Color-Logo-New.png';
---

<!doctype html>
<html lang="en">
<head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={SITE_TITLE} />
    <meta property="og:description" content={SITE_DESCRIPTION} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --bg: #0a0a0b;
            --surface: #111114;
            --surface-light: #1a1a1f;
            --text: #f0f0f0;
            --text-muted: #a1a1aa;
            --cyan: #00d4ff;
            --warm: #f59e0b;
            --warm-soft: rgba(245, 158, 11, 0.1);
            --rose: #e94560;
            --violet: #7c3aed;
            --gradient: linear-gradient(135deg, #00d4ff, #7c3aed, #e94560);
            --gradient-warm: linear-gradient(135deg, #f59e0b, #e94560, #7c3aed);
        }
        body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; background: var(--bg); color: var(--text); line-height: 1.7; overflow-x: hidden; padding-top: 70px; }
        .gradient-text-warm { background: var(--gradient-warm); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        .back-link { display: inline-flex; align-items: center; gap: 8px; color: var(--text-muted); text-decoration: none; font-size: 14px; padding: 16px 24px 0; transition: color 0.2s; }
        .back-link:hover { color: var(--violet); }
        .hero { min-height: 70vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 40px 24px; position: relative; }
        .hero::before { content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: radial-gradient(ellipse at 30% 50%, rgba(124, 58, 237, 0.08) 0%, transparent 50%), radial-gradient(ellipse at 70% 30%, rgba(0, 212, 255, 0.05) 0%, transparent 50%); pointer-events: none; }
        .hero-content { max-width: 720px; position: relative; z-index: 1; }
        .hero-icon { font-size: 64px; margin-bottom: 24px; }
        .hero-label { display: inline-block; padding: 8px 20px; background: rgba(124, 58, 237, 0.1); border: 1px solid rgba(124, 58, 237, 0.3); border-radius: 100px; font-size: 14px; font-weight: 600; color: var(--violet); margin-bottom: 24px; letter-spacing: 0.05em; text-transform: uppercase; }
        .hero h1 { font-size: clamp(32px, 5vw, 56px); font-weight: 800; line-height: 1.15; margin-bottom: 20px; }
        .hero p { font-size: 19px; color: var(--text-muted); margin-bottom: 32px; line-height: 1.6; }
        .hero-quote { font-size: 17px; font-style: italic; color: var(--text-muted); border-left: 3px solid var(--violet); padding-left: 20px; margin: 32px 0; text-align: left; }
        .btn-primary { display: inline-block; padding: 18px 40px; background: var(--gradient-warm); color: white; font-size: 18px; font-weight: 700; text-decoration: none; border-radius: 16px; transition: transform 0.2s, box-shadow 0.2s; }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(124, 58, 237, 0.3); }
        .btn-outline { display: inline-block; padding: 14px 32px; background: transparent; color: var(--violet); font-size: 16px; font-weight: 600; text-decoration: none; border-radius: 12px; border: 1px solid rgba(124, 58, 237, 0.4); transition: all 0.2s; }
        .btn-outline:hover { background: rgba(124, 58, 237, 0.1); }
        .section { padding: 80px 24px; max-width: 1100px; margin: 0 auto; }
        .section-title { font-size: clamp(26px, 4vw, 40px); font-weight: 800; text-align: center; margin-bottom: 16px; }
        .section-sub { font-size: 18px; color: var(--text-muted); text-align: center; max-width: 640px; margin: 0 auto 60px; }
        .features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }
        .feature-card { background: var(--surface); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 20px; padding: 32px; }
        .feature-card .icon { font-size: 32px; margin-bottom: 12px; }
        .feature-card h3 { font-size: 18px; font-weight: 700; margin-bottom: 8px; }
        .feature-card p { color: var(--text-muted); font-size: 15px; line-height: 1.6; }
        .steps { display: flex; flex-direction: column; gap: 48px; max-width: 640px; margin: 0 auto; }
        .step { display: flex; gap: 24px; align-items: flex-start; }
        .step-number { width: 48px; height: 48px; background: var(--gradient-warm); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 800; color: white; flex-shrink: 0; }
        .step-content h3 { font-size: 20px; font-weight: 700; margin-bottom: 8px; }
        .step-content p { color: var(--text-muted); font-size: 16px; }
        .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }
        .pricing-card { background: var(--surface); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 20px; padding: 40px 32px; text-align: center; transition: transform 0.25s, border-color 0.25s; }
        .pricing-card:hover { transform: translateY(-4px); border-color: rgba(124, 58, 237, 0.3); }
        .pricing-card.featured { border-color: rgba(124, 58, 237, 0.4); background: linear-gradient(180deg, rgba(124, 58, 237, 0.05), var(--surface)); }
        .pricing-label { font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--violet); margin-bottom: 8px; }
        .pricing-card h3 { font-size: 24px; font-weight: 800; margin-bottom: 8px; }
        .pricing-amount { font-size: 48px; font-weight: 800; margin-bottom: 4px; }
        .pricing-amount .period { font-size: 16px; font-weight: 400; color: var(--text-muted); }
        .pricing-desc { color: var(--text-muted); font-size: 15px; margin-bottom: 24px; }
        .pricing-features { list-style: none; text-align: left; margin-bottom: 32px; }
        .pricing-features li { padding: 8px 0; border-bottom: 1px solid rgba(255, 255, 255, 0.04); font-size: 15px; color: var(--text-muted); }
        .pricing-features li::before { content: '✓ '; color: var(--violet); font-weight: 700; }
        .cta { text-align: center; padding: 80px 24px; }
        .cta h2 { font-size: clamp(28px, 4vw, 42px); font-weight: 800; margin-bottom: 16px; }
        .cta p { font-size: 18px; color: var(--text-muted); margin-bottom: 32px; max-width: 540px; margin-left: auto; margin-right: auto; }
        @media (max-width: 768px) {
            .hero { padding: 40px 20px; }
            .section { padding: 60px 20px; }
            .pricing-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
 <Navigation />
    <a href="/" class="back-link">← Back to all services</a>

    <section class="hero">
        <div class="hero-content">
            <div class="hero-icon">💫</div>
            <div class="hero-label">Dream Journal</div>
            <h1>Map Your <span class="gradient-text-warm">Inner World</span></h1>
            <p>Tell us your dream when you wake up. We ask what it means to you. We draw the scene. We compose music that matches the feeling. Over time, we map your inner world.</p>
            <div class="hero-quote">
                "The AI painted the house I keep dreaming about. I didn't even know it was important until I saw it."
            </div>
            <a href="mailto:stories@cc3po.com?subject=Dream%20Journal%20-%20I%20want%20to%20start%20dream%20journaling" class="btn-primary">Start Dream Journaling</a>
        </div>
    </section>

    <section class="section">
        <h2 class="section-title">What You <span class="gradient-text-warm">Get</span></h2>
        <p class="section-sub">Not a dream dictionary — a visual, musical map of your subconscious.</p>
        <div class="features-grid">
            <div class="feature-card">
                <div class="icon">📓</div>
                <h3>Dream Log</h3>
                <p>Tell us your dream when you wake up. Voice, text, whatever works. We capture it, preserve it, and help you remember what you'd normally forget by lunch.</p>
            </div>
            <div class="feature-card">
                <div class="icon">🎨</div>
                <h3>AI-Generated Artwork</h3>
                <p>We take your dream and paint it. Not literally — impressionistically. The house you keep visiting. The ocean you keep swimming in. The face you almost recognize. Made visible.</p>
            </div>
            <div class="feature-card">
                <div class="icon">🎵</div>
                <h3>Composed Music</h3>
                <p>Music that matches the feeling of your dream. Not generic ambient — a unique composition that sounds like how the dream felt. Eerie, peaceful, urgent, floating. Whatever it was.</p>
            </div>
            <div class="feature-card">
                <div class="icon">🧠</div>
                <h3>Pattern Analysis</h3>
                <p>Over time, we spot the patterns. The recurring themes. The emotional arcs. The symbols that keep showing up. We help you understand what your subconscious is working through.</p>
            </div>
            <div class="feature-card">
                <div class="icon">🗺️</div>
                <h3>Inner World Map</h3>
                <p>A visual map of your dream landscape. The places you return to, the themes that repeat, the emotional territories your mind explores night after night. Your inner world, charted.</p>
            </div>
            <div class="feature-card">
                <div class="icon">🔒</div>
                <h3>Private & Secure</h3>
                <p>Your dreams are the most private thing you have. We treat them that way. No sharing, no training, no data selling. Your subconscious belongs to you.</p>
            </div>
        </div>
    </section>

    <section class="section">
        <h2 class="section-title">How It <span class="gradient-text-warm">Works</span></h2>
        <p class="section-sub">From waking to understanding — your dreams, decoded with care.</p>
        <div class="steps">
            <div class="step">
                <div class="step-number">1</div>
                <div class="step-content">
                    <h3>Tell Us Your Dream</h3>
                    <p>Wake up, grab your phone, and tell us what happened. Voice memo, text, whatever feels right. Don't edit — just describe what you remember. We'll ask follow-up questions.</p>
                </div>
            </div>
            <div class="step">
                <div class="step-number">2</div>
                <div class="step-content">
                    <h3>We Create</h3>
                    <p>We paint the scene. We compose the music. We map the symbols. Not a clinical interpretation — a creative one. One that honors the mystery instead of trying to solve it.</p>
                </div>
            </div>
            <div class="step">
                <div class="step-number">3</div>
                <div class="step-content">
                    <h3>You Explore</h3>
                    <p>See your dream rendered in art. Hear the music that matches the feeling. Read the interpretation. Decide what resonates and what doesn't. It's your dream — you're the expert.</p>
                </div>
            </div>
            <div class="step">
                <div class="step-number">4</div>
                <div class="step-content">
                    <h3>Patterns Emerge</h3>
                    <p>After a few weeks, patterns start to appear. Recurring places. Recurring emotions. Themes your subconscious keeps returning to. Your inner world starts to make sense — not as a puzzle to solve, but as a landscape to explore.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="section">
        <h2 class="section-title">Choose Your <span class="gradient-text-warm">Journey</span></h2>
        <p class="section-sub">Start small or go deep — your dreams are worth exploring.</p>
        <div class="pricing-grid">
            <div class="pricing-card">
                <div class="pricing-label">Starter</div>
                <h3>Starter</h3>
                <div class="pricing-amount">$9<span class="period">/mo</span></div>
                <p class="pricing-desc">Begin your dream journey</p>
                <ul class="pricing-features">
                    <li>Up to 10 dreams per month</li>
                    <li>Dream log & journal</li>
                    <li>AI-generated artwork</li>
                    <li>Dream interpretations</li>
                    <li>Basic pattern tracking</li>
                    <li>Cancel anytime</li>
                </ul>
                <a href="mailto:stories@cc3po.com?subject=Dream%20Journal%20-%20Starter%20%289%2Fmo%29" class="btn-outline">Start Dream Journaling</a>
            </div>
            <div class="pricing-card featured">
                <div class="pricing-label">⭐ Most Popular</div>
                <h3>Explorer</h3>
                <div class="pricing-amount">$19<span class="period">/mo</span></div>
                <p class="pricing-desc">Unlimited dreams + art + deeper insights</p>
                <ul class="pricing-features">
                    <li>Unlimited dreams</li>
                    <li>Dream log & journal</li>
                    <li>AI-generated artwork for every dream</li>
                    <li>Dream interpretations</li>
                    <li>Advanced pattern tracking</li>
                    <li>Weekly dream summary</li>
                    <li>Cancel anytime</li>
                </ul>
                <a href="mailto:stories@cc3po.com?subject=Dream%20Journal%20-%20Explorer%20%2819%2Fmo%29" class="btn-primary">Start Dream Journaling</a>
            </div>
            <div class="pricing-card">
                <div class="pricing-label">Deep Diver</div>
                <h3>Deep Diver</h3>
                <div class="pricing-amount">$29<span class="period">/mo</span></div>
                <p class="pricing-desc">Unlimited + music + full pattern analysis</p>
                <ul class="pricing-features">
                    <li>Unlimited dreams</li>
                    <li>Dream log & journal</li>
                    <li>AI-generated artwork for every dream</li>
                    <li>Composed music for every dream</li>
                    <li>Advanced pattern analysis</li>
                    <li>Inner world map</li>
                    <li>Monthly deep-dive report</li>
                    <li>Personal dream advisor</li>
                    <li>Cancel anytime</li>
                </ul>
                <a href="mailto:stories@cc3po.com?subject=Dream%20Journal%20-%20Deep%20Diver%20%2829%2Fmo%29" class="btn-outline">Start Deep Diving</a>
            </div>
        </div>
    </section>

    <section class="cta">
        <h2>Ready to map your <span class="gradient-text-warm">inner world</span>?</h2>
        <p>Your dreams are trying to tell you something. Let's listen together.</p>
        <a href="mailto:stories@cc3po.com?subject=Dream%20Journal%20-%20I%20want%20to%20start%20dream%20journaling" class="btn-primary">Start Dream Journaling</a>
        <p style="margin-top: 24px; font-size: 14px; color: var(--text-muted);">Or email us at stories@cc3po.com — we'll set up a time to talk.</p>
    </section>

    <Footer />
</body>
</html>