---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';

const SITE_TITLE = 'Living Memorial — A Memorial That Grows | CC3PO Stories';
const SITE_DESCRIPTION = 'Not a static obituary. A living tribute page with music, stories, photos, and family contributions. It grows. It breathes. It doesn\'t fade. Starting at $199/yr.';
const canonicalURL = new URL(Astro.url.pathname, 'https://stories.cc3po.com');
const ogImage = 'https://cc3po.com/wp-content/uploads/2026/04/Color-Logo-New.png';
---

<!doctype html>
<html lang="en">
<head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={SITE_TITLE} />
    <meta property="og:description" content={SITE_DESCRIPTION} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --bg: #0a0a0b;
            --surface: #111114;
            --surface-light: #1a1a1f;
            --text: #f0f0f0;
            --text-muted: #a1a1aa;
            --cyan: #00d4ff;
            --warm: #f59e0b;
            --warm-soft: rgba(245, 158, 11, 0.1);
            --rose: #e94560;
            --violet: #7c3aed;
            --gradient: linear-gradient(135deg, #00d4ff, #7c3aed, #e94560);
            --gradient-warm: linear-gradient(135deg, #f59e0b, #e94560, #7c3aed);
        }
        body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; background: var(--bg); color: var(--text); line-height: 1.7; overflow-x: hidden; }
        .gradient-text-warm { background: var(--gradient-warm); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        .back-link { display: inline-flex; align-items: center; gap: 8px; color: var(--text-muted); text-decoration: none; font-size: 14px; padding: 16px 24px 0; transition: color 0.2s; }
        .back-link:hover { color: var(--warm); }
        .hero { min-height: 70vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 40px 24px; position: relative; }
        .hero::before { content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: radial-gradient(ellipse at 50% 50%, rgba(245, 158, 11, 0.06) 0%, transparent 60%); pointer-events: none; }
        .hero-content { max-width: 720px; position: relative; z-index: 1; }
        .hero-icon { font-size: 64px; margin-bottom: 24px; }
        .hero-label { display: inline-block; padding: 8px 20px; background: var(--warm-soft); border: 1px solid rgba(245, 158, 11, 0.3); border-radius: 100px; font-size: 14px; font-weight: 600; color: var(--warm); margin-bottom: 24px; letter-spacing: 0.05em; text-transform: uppercase; }
        .hero h1 { font-size: clamp(32px, 5vw, 56px); font-weight: 800; line-height: 1.15; margin-bottom: 20px; }
        .hero p { font-size: 19px; color: var(--text-muted); margin-bottom: 32px; line-height: 1.6; }
        .hero-quote { font-size: 17px; font-style: italic; color: var(--text-muted); border-left: 3px solid var(--warm); padding-left: 20px; margin: 32px 0; text-align: left; }
        .btn-primary { display: inline-block; padding: 18px 40px; background: var(--gradient-warm); color: white; font-size: 18px; font-weight: 700; text-decoration: none; border-radius: 16px; transition: transform 0.2s, box-shadow 0.2s; }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(245, 158, 11, 0.3); }
        .btn-outline { display: inline-block; padding: 14px 32px; background: transparent; color: var(--warm); font-size: 16px; font-weight: 600; text-decoration: none; border-radius: 12px; border: 1px solid rgba(245, 158, 11, 0.4); transition: all 0.2s; }
        .btn-outline:hover { background: rgba(245, 158, 11, 0.1); }
        .section { padding: 80px 24px; max-width: 1100px; margin: 0 auto; }
        .section-title { font-size: clamp(26px, 4vw, 40px); font-weight: 800; text-align: center; margin-bottom: 16px; }
        .section-sub { font-size: 18px; color: var(--text-muted); text-align: center; max-width: 640px; margin: 0 auto 60px; }
        .features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }
        .feature-card { background: var(--surface); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 20px; padding: 32px; }
        .feature-card .icon { font-size: 32px; margin-bottom: 12px; }
        .feature-card h3 { font-size: 18px; font-weight: 700; margin-bottom: 8px; }
        .feature-card p { color: var(--text-muted); font-size: 15px; line-height: 1.6; }
        .steps { display: flex; flex-direction: column; gap: 48px; max-width: 640px; margin: 0 auto; }
        .step { display: flex; gap: 24px; align-items: flex-start; }
        .step-number { width: 48px; height: 48px; background: var(--gradient-warm); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 800; color: white; flex-shrink: 0; }
        .step-content h3 { font-size: 20px; font-weight: 700; margin-bottom: 8px; }
        .step-content p { color: var(--text-muted); font-size: 16px; }
        .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }
        .pricing-card { background: var(--surface); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 20px; padding: 40px 32px; text-align: center; transition: transform 0.25s, border-color 0.25s; }
        .pricing-card:hover { transform: translateY(-4px); border-color: rgba(245, 158, 11, 0.3); }
        .pricing-card.featured { border-color: rgba(245, 158, 11, 0.4); background: linear-gradient(180deg, rgba(245, 158, 11, 0.05), var(--surface)); }
        .pricing-label { font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--warm); margin-bottom: 8px; }
        .pricing-card h3 { font-size: 24px; font-weight: 800; margin-bottom: 8px; }
        .pricing-amount { font-size: 48px; font-weight: 800; margin-bottom: 4px; }
        .pricing-amount .period { font-size: 16px; font-weight: 400; color: var(--text-muted); }
        .pricing-desc { color: var(--text-muted); font-size: 15px; margin-bottom: 24px; }
        .pricing-features { list-style: none; text-align: left; margin-bottom: 32px; }
        .pricing-features li { padding: 8px 0; border-bottom: 1px solid rgba(255, 255, 255, 0.04); font-size: 15px; color: var(--text-muted); }
        .pricing-features li::before { content: '✓ '; color: var(--warm); font-weight: 700; }
        .cta { text-align: center; padding: 80px 24px; }
        .cta h2 { font-size: clamp(28px, 4vw, 42px); font-weight: 800; margin-bottom: 16px; }
        .cta p { font-size: 18px; color: var(--text-muted); margin-bottom: 32px; max-width: 540px; margin-left: auto; margin-right: auto; }
        @media (max-width: 768px) {
            .hero { padding: 40px 20px; }
            .section { padding: 60px 20px; }
            .pricing-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <a href="/" class="back-link">← Back to all services</a>

    <section class="hero">
        <div class="hero-content">
            <div class="hero-icon">🕯️</div>
            <div class="hero-label">Living Memorial</div>
            <h1>A Memorial That <span class="gradient-text-warm">Grows</span></h1>
            <p>Not a static obituary. A living page that plays their favorite music, tells their story in their voice, and lets family add memories over time. It grows. It breathes. It doesn't fade.</p>
            <div class="hero-quote">
                "My mom's memorial page has her laugh on it. I visit it every morning."
            </div>
            <a href="mailto:stories@cc3po.com?subject=Living%20Memorial%20-%20I%20want%20to%20create%20a%20memorial" class="btn-primary">Create a Memorial</a>
        </div>
    </section>

    <section class="section">
        <h2 class="section-title">What You <span class="gradient-text-warm">Get</span></h2>
        <p class="section-sub">Not a tribute — a living space where someone's memory continues to grow.</p>
        <div class="features-grid">
            <div class="feature-card">
                <div class="icon">🌐</div>
                <h3>Personal Memorial Page</h3>
                <p>A beautiful, dedicated page that tells their story. Their photo, their timeline, their favorite quotes. Not a template — something as unique as they were.</p>
            </div>
            <div class="feature-card">
                <div class="icon">🎵</div>
                <h3>Music Integration</h3>
                <p>Their favorite songs. A personal song composed for them. Music that plays when you visit. Sound brings memories back in a way words alone can't.</p>
            </div>
            <div class="feature-card">
                <div class="icon">👨‍👩‍👧‍👦</div>
                <h3>Family Contribution Portal</h3>
                <p>Family and friends can add their own memories, photos, and stories. The memorial grows over time — because a person's story doesn't end, it just gets more voices.</p>
            </div>
            <div class="feature-card">
                <div class="icon">📱</div>
                <h3>QR Code for Physical Memorial</h3>
                <p>A QR code you can place at a grave, a bench, a plaque. Anyone who visits can scan it and instantly see the memorial. The physical meets the digital.</p>
            </div>
            <div class="feature-card">
                <div class="icon">📖</div>
                <h3>Story Collection</h3>
                <p>We interview family and friends to collect stories. Not just the big moments — the small ones. The way they made coffee. The jokes they told. The things everyone remembers but no one wrote down.</p>
            </div>
            <div class="feature-card">
                <div class="icon">🔒</div>
                <h3>Privacy Controls</h3>
                <p>Choose who can see and contribute. Keep it private for family, or open it to anyone who knew them. You control who sees their story.</p>
            </div>
        </div>
    </section>

    <section class="section">
        <h2 class="section-title">How It <span class="gradient-text-warm">Works</span></h2>
        <p class="section-sub">From grief to growth — a memorial that keeps their memory alive.</p>
        <div class="steps">
            <div class="step">
                <div class="step-number">1</div>
                <div class="step-content">
                    <h3>Tell Us About Them</h3>
                    <p>You share their name, their story, their favorite things. We ask the questions that help us understand who they were — not just what happened, but how they made people feel.</p>
                </div>
            </div>
            <div class="step">
                <div class="step-number">2</div>
                <div class="step-content">
                    <h3>We Create the Page</h3>
                    <p>We build a memorial page that reflects who they were. Photos, music, stories, timeline. It's not generic — it's personal. You review it and tell us what to change.</p>
                </div>
            </div>
            <div class="step">
                <div class="step-number">3</div>
                <div class="step-content">
                    <h3>Family Adds Memories</h3>
                    <p>Invite family and friends to contribute. Their own stories, photos, voice recordings. Every person adds another layer. The memorial becomes richer over time.</p>
                </div>
            </div>
            <div class="step">
                <div class="step-number">4</div>
                <div class="step-content">
                    <h3>It Grows Forever</h3>
                    <p>The memorial stays live and keeps growing. New memories get added. Birthdays are acknowledged. Anniversaries are remembered. It doesn't fade — it deepens.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="section">
        <h2 class="section-title">Choose Your <span class="gradient-text-warm">Memorial</span></h2>
        <p class="section-sub">Every memorial keeps their memory alive. The difference is how it grows.</p>
        <div class="pricing-grid">
            <div class="pricing-card">
                <div class="pricing-label">Essential</div>
                <h3>Essential</h3>
                <div class="pricing-amount">$199<span class="period">/yr</span></div>
                <p class="pricing-desc">A beautiful memorial page</p>
                <ul class="pricing-features">
                    <li>Personal memorial page</li>
                    <li>Photo gallery (up to 20)</li>
                    <li>Timeline & biography</li>
                    <li>Music integration</li>
                    <li>Up to 5 family contributors</li>
                    <li>QR code for physical memorial</li>
                    <li>Annual renewal</li>
                </ul>
                <a href="mailto:stories@cc3po.com?subject=Living%20Memorial%20-%20Essential%20%28199%2Fyr%29" class="btn-outline">Create a Memorial</a>
            </div>
            <div class="pricing-card featured">
                <div class="pricing-label">⭐ Most Popular</div>
                <h3>Complete</h3>
                <div class="pricing-amount">$399<span class="period">/yr</span></div>
                <p class="pricing-desc">Full memorial with family contributions</p>
                <ul class="pricing-features">
                    <li>Everything in Essential</li>
                    <li>Unlimited photos</li>
                    <li>Unlimited family contributors</li>
                    <li>Story collection interviews</li>
                    <li>Voice recording integration</li>
                    <li>Custom domain option</li>
                    <li>Priority support</li>
                    <li>Annual renewal</li>
                </ul>
                <a href="mailto:stories@cc3po.com?subject=Living%20Memorial%20-%20Complete%20%28399%2Fyr%29" class="btn-primary">Create a Memorial</a>
            </div>
            <div class="pricing-card">
                <div class="pricing-label">Legacy</div>
                <h3>Perpetual</h3>
                <div class="pricing-amount">$999</div>
                <p class="pricing-desc">One-time — maintained forever</p>
                <ul class="pricing-features">
                    <li>Everything in Complete</li>
                    <li>One-time payment, no renewal</li>
                    <li>Maintained in perpetuity</li>
                    <li>Endowment for permanent hosting</li>
                    <li>Professional story collection</li>
                    <li>Personal song composed for them</li>
                    <li>Physical keepsake book included</li>
                    <li>Legacy guarantee</li>
                </ul>
                <a href="mailto:stories@cc3po.com?subject=Living%20Memorial%20-%20Perpetual%20%28999%29" class="btn-outline">Create a Perpetual Memorial</a>
            </div>
        </div>
    </section>

    <section class="cta">
        <h2>Ready to create a memorial that <span class="gradient-text-warm">grows</span>?</h2>
        <p>A memorial should be as alive as the person it honors. Let's build something that breathes.</p>
        <a href="mailto:stories@cc3po.com?subject=Living%20Memorial%20-%20I%20want%20to%20create%20a%20memorial" class="btn-primary">Create a Memorial</a>
        <p style="margin-top: 24px; font-size: 14px; color: var(--text-muted);">Or email us at stories@cc3po.com — we'll set up a time to talk.</p>
    </section>

    <Footer />
</body>
</html>