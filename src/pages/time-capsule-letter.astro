---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';

const SITE_TITLE = 'Time Capsule Letter — Words That Arrive When They\'re Needed Most | CC3PO Stories';
const SITE_DESCRIPTION = 'Write a letter to someone for a future date. To your daughter on her wedding day. To yourself at 40. We hold it and deliver it when the time comes. Starting at $99.';
const canonicalURL = new URL(Astro.url.pathname, 'https://stories.cc3po.com');
const ogImage = 'https://cc3po.com/wp-content/uploads/2026/04/Color-Logo-New.png';
---

<!doctype html>
<html lang="en">
<head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={SITE_TITLE} />
    <meta property="og:description" content={SITE_DESCRIPTION} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --bg: #0a0a0b;
            --surface: #111114;
            --surface-light: #1a1a1f;
            --text: #f0f0f0;
            --text-muted: #a1a1aa;
            --cyan: #00d4ff;
            --warm: #f59e0b;
            --warm-soft: rgba(245, 158, 11, 0.1);
            --rose: #e94560;
            --violet: #7c3aed;
            --gradient: linear-gradient(135deg, #00d4ff, #7c3aed, #e94560);
            --gradient-warm: linear-gradient(135deg, #f59e0b, #e94560, #7c3aed);
        }
        body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; background: var(--bg); color: var(--text); line-height: 1.7; overflow-x: hidden; }
        .gradient-text-warm { background: var(--gradient-warm); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        .back-link { display: inline-flex; align-items: center; gap: 8px; color: var(--text-muted); text-decoration: none; font-size: 14px; padding: 16px 24px 0; transition: color 0.2s; }
        .back-link:hover { color: var(--warm); }
        .hero { min-height: 70vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 40px 24px; position: relative; }
        .hero::before { content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: radial-gradient(ellipse at 50% 50%, rgba(0, 212, 255, 0.06) 0%, transparent 60%); pointer-events: none; }
        .hero-content { max-width: 720px; position: relative; z-index: 1; }
        .hero-icon { font-size: 64px; margin-bottom: 24px; }
        .hero-label { display: inline-block; padding: 8px 20px; background: rgba(0, 212, 255, 0.1); border: 1px solid rgba(0, 212, 255, 0.3); border-radius: 100px; font-size: 14px; font-weight: 600; color: var(--cyan); margin-bottom: 24px; letter-spacing: 0.05em; text-transform: uppercase; }
        .hero h1 { font-size: clamp(32px, 5vw, 56px); font-weight: 800; line-height: 1.15; margin-bottom: 20px; }
        .hero p { font-size: 19px; color: var(--text-muted); margin-bottom: 32px; line-height: 1.6; }
        .hero-quote { font-size: 17px; font-style: italic; color: var(--text-muted); border-left: 3px solid var(--cyan); padding-left: 20px; margin: 32px 0; text-align: left; }
        .btn-primary { display: inline-block; padding: 18px 40px; background: var(--gradient-warm); color: white; font-size: 18px; font-weight: 700; text-decoration: none; border-radius: 16px; transition: transform 0.2s, box-shadow 0.2s; }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(0, 212, 255, 0.3); }
        .btn-outline { display: inline-block; padding: 14px 32px; background: transparent; color: var(--cyan); font-size: 16px; font-weight: 600; text-decoration: none; border-radius: 12px; border: 1px solid rgba(0, 212, 255, 0.4); transition: all 0.2s; }
        .btn-outline:hover { background: rgba(0, 212, 255, 0.1); }
        .section { padding: 80px 24px; max-width: 1100px; margin: 0 auto; }
        .section-title { font-size: clamp(26px, 4vw, 40px); font-weight: 800; text-align: center; margin-bottom: 16px; }
        .section-sub { font-size: 18px; color: var(--text-muted); text-align: center; max-width: 640px; margin: 0 auto 60px; }
        .features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }
        .feature-card { background: var(--surface); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 20px; padding: 32px; }
        .feature-card .icon { font-size: 32px; margin-bottom: 12px; }
        .feature-card h3 { font-size: 18px; font-weight: 700; margin-bottom: 8px; }
        .feature-card p { color: var(--text-muted); font-size: 15px; line-height: 1.6; }
        .steps { display: flex; flex-direction: column; gap: 48px; max-width: 640px; margin: 0 auto; }
        .step { display: flex; gap: 24px; align-items: flex-start; }
        .step-number { width: 48px; height: 48px; background: var(--gradient-warm); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 800; color: white; flex-shrink: 0; }
        .step-content h3 { font-size: 20px; font-weight: 700; margin-bottom: 8px; }
        .step-content p { color: var(--text-muted); font-size: 16px; }
        .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }
        .pricing-card { background: var(--surface); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 20px; padding: 40px 32px; text-align: center; transition: transform 0.25s, border-color 0.25s; }
        .pricing-card:hover { transform: translateY(-4px); border-color: rgba(0, 212, 255, 0.3); }
        .pricing-card.featured { border-color: rgba(0, 212, 255, 0.4); background: linear-gradient(180deg, rgba(0, 212, 255, 0.05), var(--surface)); }
        .pricing-label { font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--cyan); margin-bottom: 8px; }
        .pricing-card h3 { font-size: 24px; font-weight: 800; margin-bottom: 8px; }
        .pricing-amount { font-size: 48px; font-weight: 800; margin-bottom: 4px; }
        .pricing-desc { color: var(--text-muted); font-size: 15px; margin-bottom: 24px; }
        .pricing-features { list-style: none; text-align: left; margin-bottom: 32px; }
        .pricing-features li { padding: 8px 0; border-bottom: 1px solid rgba(255, 255, 255, 0.04); font-size: 15px; color: var(--text-muted); }
        .pricing-features li::before { content: '✓ '; color: var(--cyan); font-weight: 700; }
        .cta { text-align: center; padding: 80px 24px; }
        .cta h2 { font-size: clamp(28px, 4vw, 42px); font-weight: 800; margin-bottom: 16px; }
        .cta p { font-size: 18px; color: var(--text-muted); margin-bottom: 32px; max-width: 540px; margin-left: auto; margin-right: auto; }
        @media (max-width: 768px) {
            .hero { padding: 40px 20px; }
            .section { padding: 60px 20px; }
            .pricing-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <a href="/" class="back-link">← Back to all services</a>

    <section class="hero">
        <div class="hero-content">
            <div class="hero-icon">✉️</div>
            <div class="hero-label">Time Capsule Letter</div>
            <h1>Words That Arrive When They're <span class="gradient-text-warm">Needed Most</span></h1>
            <p>Write a letter to someone for a future date. To your daughter on her wedding day. To your spouse on your 50th anniversary. To yourself at 40, written when you're 30. We hold it and deliver it when the time comes.</p>
            <div class="hero-quote">
                "My dad wrote me a letter when I was 5. I got it on my 21st birthday. He'd been gone 10 years."
            </div>
            <a href="mailto:stories@cc3po.com?subject=Time%20Capsule%20Letter%20-%20I%20want%20to%20write%20a%20letter" class="btn-primary">Write Your Letter</a>
        </div>
    </section>

    <section class="section">
        <h2 class="section-title">What You <span class="gradient-text-warm">Get</span></h2>
        <p class="section-sub">Not an email scheduler — a promise. Held safely until the right moment arrives.</p>
        <div class="features-grid">
            <div class="feature-card">
                <div class="icon">💌</div>
                <h3>Physical Letter</h3>
                <p>A real letter, printed on quality paper, sealed in an envelope. Not a text that gets buried — a tangible thing someone holds in their hands on a day that matters.</p>
            </div>
            <div class="feature-card">
                <div class="icon">💾</div>
                <h3>Digital Copy</h3>
                <p>A digital backup stored securely. Because some things are too important to exist in only one place. You get peace of mind knowing it's preserved.</p>
            </div>
            <div class="feature-card">
                <div class="icon">📅</div>
                <h3>Confirmed Delivery Date</h3>
                <p>You choose when the letter arrives. A birthday. A graduation. An anniversary. We confirm the date and hold it until then. No early peeks.</p>
            </div>
            <div class="feature-card">
                <div class="icon">✍️</div>
                <h3>Writing Guidance</h3>
                <p>Not sure what to say? Our village helps you find the words. We ask the questions that unlock what you really want to say — the things that matter most.</p>
            </div>
            <div class="feature-card">
                <div class="icon">🎵</div>
                <h3>Optional Audio Recording</h3>
                <p>Record your voice reading the letter. So they hear your tone, your pause, your emotion — not just your words. Available as an add-on.</p>
            </div>
            <div class="feature-card">
                <div class="icon">🔒</div>
                <h3>Held in Trust</h3>
                <p>Your letter is stored securely and privately. No one reads it, no one shares it. It waits until the day you chose, then it arrives — exactly as you wrote it.</p>
            </div>
        </div>
    </section>

    <section class="section">
        <h2 class="section-title">How It <span class="gradient-text-warm">Works</span></h2>
        <p class="section-sub">From your heart to their hands — we keep it safe until the time is right.</p>
        <div class="steps">
            <div class="step">
                <div class="step-number">1</div>
                <div class="step-content">
                    <h3>Write Your Letter</h3>
                    <p>Tell us who it's for, when it should arrive, and what you want to say. We can help you find the words — or you write it yourself and we make sure it gets there.</p>
                </div>
            </div>
            <div class="step">
                <div class="step-number">2</div>
                <div class="step-content">
                    <h3>We Secure It</h3>
                    <p>Your letter is sealed, stored, and scheduled. We confirm the delivery date and give you a tracking reference. You know exactly when it will arrive.</p>
                </div>
            </div>
            <div class="step">
                <div class="step-number">3</div>
                <div class="step-content">
                    <h3>Time Passes</h3>
                    <p>Years might go by. That's okay. Your letter waits. We maintain it securely — digital backups, physical preservation, and reminders to you before delivery.</p>
                </div>
            </div>
            <div class="step">
                <div class="step-number">4</div>
                <div class="step-content">
                    <h3>It Arrives</h3>
                    <p>On the date you chose, the letter is delivered. Physical and digital. They hold your words — maybe from years ago, maybe from someone who's no longer here. Exactly when they needed to hear them.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="section">
        <h2 class="section-title">Choose Your <span class="gradient-text-warm">Package</span></h2>
        <p class="section-sub">One letter or a lifetime of letters — every word delivered when it matters.</p>
        <div class="pricing-grid">
            <div class="pricing-card">
                <div class="pricing-label">Single</div>
                <h3>Single Letter</h3>
                <div class="pricing-amount">$99</div>
                <p class="pricing-desc">One letter, one delivery date</p>
                <ul class="pricing-features">
                    <li>Physical letter in sealed envelope</li>
                    <li>Digital copy stored securely</li>
                    <li>Confirmed delivery date</li>
                    <li>Writing guidance (optional)</li>
                    <li>Pre-delivery reminder</li>
                    <li>Delivered on your chosen date</li>
                </ul>
                <a href="mailto:stories@cc3po.com?subject=Time%20Capsule%20Letter%20-%20Single%20Letter%20%2899%29" class="btn-outline">Write Your Letter</a>
            </div>
            <div class="pricing-card featured">
                <div class="pricing-label">⭐ Most Popular</div>
                <h3>Love Letter Set</h3>
                <div class="pricing-amount">$249</div>
                <p class="pricing-desc">5 letters delivered over 5 years</p>
                <ul class="pricing-features">
                    <li>5 physical letters, each sealed</li>
                    <li>Digital copies of all letters</li>
                    <li>5 confirmed delivery dates</li>
                    <li>Writing guidance for each letter</li>
                    <li>Audio recording add-on available</li>
                    <li>Pre-delivery reminders</li>
                    <li>Annual status updates</li>
                </ul>
                <a href="mailto:stories@cc3po.com?subject=Time%20Capsule%20Letter%20-%20Love%20Letter%20Set%20%28249%29" class="btn-primary">Write Your Letters</a>
            </div>
            <div class="pricing-card">
                <div class="pricing-label">Legacy</div>
                <h3>Family Vault</h3>
                <div class="pricing-amount">$499</div>
                <p class="pricing-desc">10 letters + secure storage</p>
                <ul class="pricing-features">
                    <li>10 physical letters, each sealed</li>
                    <li>Digital copies with encryption</li>
                    <li>10 confirmed delivery dates</li>
                    <li>Writing guidance for each letter</li>
                    <li>Audio recording included</li>
                    <li>Secure long-term storage</li>
                    <li>Family access portal</li>
                    <li>Annual status updates</li>
                </ul>
                <a href="mailto:stories@cc3po.com?subject=Time%20Capsule%20Letter%20-%20Family%20Vault%20%28499%29" class="btn-outline">Create Your Vault</a>
            </div>
        </div>
    </section>

    <section class="cta">
        <h2>Ready to write a letter that <span class="gradient-text-warm">matters</span>?</h2>
        <p>Some words need time to find their moment. Write them now, and let them arrive exactly when they're needed.</p>
        <a href="mailto:stories@cc3po.com?subject=Time%20Capsule%20Letter%20-%20I%20want%20to%20write%20a%20letter" class="btn-primary">Write Your Letter</a>
        <p style="margin-top: 24px; font-size: 14px; color: var(--text-muted);">Or email us at stories@cc3po.com — we'll set up a time to talk.</p>
    </section>

    <Footer />
</body>
</html>